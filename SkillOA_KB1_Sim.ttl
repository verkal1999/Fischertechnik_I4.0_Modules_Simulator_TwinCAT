#################################################################

###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#op_bindsParameterType
KB1_ASRS:op_bindsParameterType rdf:type owl:ObjectProperty ;
                               rdfs:domain KB1_ASRS:class_ParameterBinding ;
                               rdfs:range KB1_ASRS:class_ParameterType .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#op_bindsServiceRequestParameter
KB1_ASRS:op_bindsServiceRequestParameter rdf:type owl:ObjectProperty ;
                                         rdfs:domain KB1_ASRS:class_ParameterBinding ;
                                         rdfs:range KB1_ASRS:class_ServiceRequestParameter .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#op_canFulfillServiceRequest
KB1_ASRS:op_canFulfillServiceRequest rdf:type owl:ObjectProperty ;
                                     rdfs:domain KB1_ASRS:class_ProposedCapability ;
                                     rdfs:range KB1_ASRS:class_ServiceRequest .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#op_executesSkill
KB1_ASRS:op_executesSkill rdf:type owl:ObjectProperty ;
                          rdfs:domain KB1_ASRS:class_TechnicalProcessStep ;
                          rdfs:range [ rdf:type owl:Class ;
                                       owl:unionOf ( KB1_ASRS:class_BasicSkill
                                                     KB1_ASRS:class_CombinedSkill
                                                   )
                                     ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#op_hasAllowedNextPosition
KB1_ASRS:op_hasAllowedNextPosition rdf:type owl:ObjectProperty ;
                                   owl:inverseOf KB1_ASRS:op_isAllowedNextPositionOf ;
                                   rdf:type owl:IrreflexiveProperty ;
                                   rdfs:domain KB1_ASRS:class_PositionParameter ;
                                   rdfs:range KB1_ASRS:class_PositionParameter .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#op_hasAtomicSkillOfResource
KB1_ASRS:op_hasAtomicSkillOfResource rdf:type owl:ObjectProperty ;
                                     rdfs:domain KB1_ASRS:class_Resource ;
                                     rdfs:range KB1_ASRS:class_AtomicSkill ;
                                     owl:propertyChainAxiom ( KB1_ASRS:op_hasFieldDeviceOfResource
                                                              KB1_ASRS:op_realizesAtomicSkill
                                                            ) .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#op_hasFieldDevice
KB1_ASRS:op_hasFieldDevice rdf:type owl:ObjectProperty ;
                           owl:inverseOf KB1_ASRS:op_isPartOfResourceModule ;
                           rdfs:domain KB1_ASRS:class_ResourceModule ;
                           rdfs:range KB1_ASRS:class_FieldDevice .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#op_hasFieldDeviceOfResource
KB1_ASRS:op_hasFieldDeviceOfResource rdf:type owl:ObjectProperty ;
                                     rdfs:domain KB1_ASRS:class_Resource ;
                                     rdfs:range KB1_ASRS:class_FieldDevice ;
                                     owl:propertyChainAxiom ( KB1_ASRS:op_hasResourceModule
                                                              KB1_ASRS:op_hasFieldDevice
                                                            ) .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#op_hasFirstSkill
