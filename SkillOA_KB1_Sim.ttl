#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_Actuator
KB1_ASRS:class_Actuator rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( KB1_ASRS:class_FieldDevice
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty KB1_ASRS:dp_isActuator ;
                                                                     owl:hasValue "true"^^xsd:boolean
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf KB1_ASRS:class_FieldDevice ;
                        owl:disjointWith KB1_ASRS:class_Sensor .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_AtomicSkill
KB1_ASRS:class_AtomicSkill rdf:type owl:Class ;
                           rdfs:subClassOf KB1_ASRS:class_Skill ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty KB1_ASRS:op_isRealizedAtomicSkillBy ;
                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onClass KB1_ASRS:class_FieldDevice
                                           ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_BasicSkill
KB1_ASRS:class_BasicSkill rdf:type owl:Class ;
                          rdfs:subClassOf KB1_ASRS:class_Skill ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty KB1_ASRS:op_hasInputParameter ;
                                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass KB1_ASRS:class_SkillParameter
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty KB1_ASRS:op_hasOutputParameter ;
                                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass KB1_ASRS:class_SkillParameter
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty KB1_ASRS:op_usesInputAtomicSkill ;
                                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass KB1_ASRS:class_AtomicSkill
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty KB1_ASRS:op_usesOutputAtomicSkill ;
                                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass KB1_ASRS:class_AtomicSkill
                                          ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_Capability
KB1_ASRS:class_Capability rdf:type owl:Class ;
                          rdfs:subClassOf [ rdf:type owl:Restriction ;
                                            owl:onProperty KB1_ASRS:op_hasFirstSkill ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass [ rdf:type owl:Class ;
                                                          owl:unionOf ( KB1_ASRS:class_BasicSkill
                                                                        KB1_ASRS:class_CombinedSkill
                                                                      )
                                                        ]
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty KB1_ASRS:op_hasLastSkill ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass [ rdf:type owl:Class ;
                                                          owl:unionOf ( KB1_ASRS:class_BasicSkill
                                                                        KB1_ASRS:class_CombinedSkill
                                                                      )
                                                        ]
                                          ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_CombinedSkill
KB1_ASRS:class_CombinedSkill rdf:type owl:Class ;
                             rdfs:subClassOf KB1_ASRS:class_Skill ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty KB1_ASRS:op_hasSubSkill ;
                                               owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                               owl:onClass [ rdf:type owl:Class ;
                                                             owl:unionOf ( KB1_ASRS:class_BasicSkill
                                                                           KB1_ASRS:class_CombinedSkill
                                                                         )
                                                           ]
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty KB1_ASRS:op_hasFirstSubSkill ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass [ rdf:type owl:Class ;
                                                             owl:unionOf ( KB1_ASRS:class_BasicSkill
                                                                           KB1_ASRS:class_CombinedSkill
                                                                         )
                                                           ]
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty KB1_ASRS:op_hasLastSubSkill ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass [ rdf:type owl:Class ;
                                                             owl:unionOf ( KB1_ASRS:class_BasicSkill
                                                                           KB1_ASRS:class_CombinedSkill
                                                                         )
                                                           ]
                                             ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_FieldDevice
KB1_ASRS:class_FieldDevice rdf:type owl:Class ;
                           rdfs:subClassOf [ rdf:type owl:Restriction ;
                                             owl:onProperty KB1_ASRS:op_isPartOfResourceModule ;
                                             owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onClass KB1_ASRS:class_ResourceModule
                                           ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_IORole
KB1_ASRS:class_IORole rdf:type owl:Class .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_ParameterBinding
KB1_ASRS:class_ParameterBinding rdf:type owl:Class ;
                                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                  owl:onProperty KB1_ASRS:op_bindsParameterType ;
                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                  owl:onClass KB1_ASRS:class_ParameterType
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty [ owl:inverseOf KB1_ASRS:op_hasParameterBinding
                                                                 ] ;
                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                  owl:onClass KB1_ASRS:class_TechnicalProcessStep
                                                ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_ParameterType
KB1_ASRS:class_ParameterType rdf:type owl:Class .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_PositionParameter
KB1_ASRS:class_PositionParameter rdf:type owl:Class ;
                                 rdfs:subClassOf KB1_ASRS:class_SkillParameter .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_ProposedCapability
KB1_ASRS:class_ProposedCapability rdf:type owl:Class ;
                                  rdfs:subClassOf KB1_ASRS:class_Capability .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_Resource
KB1_ASRS:class_Resource rdf:type owl:Class ;
                        rdfs:subClassOf [ rdf:type owl:Restriction ;
                                          owl:onProperty KB1_ASRS:op_hasResourceModule ;
                                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onClass KB1_ASRS:class_ResourceModule
                                        ] ;
                        rdfs:comment "Repräsentiert die physische Maschine / das physische Asset, die vom SkillOA gemanagt wird und aus Feldgeräten (Sensoren/Aktoren) besteht sowie verschiedenen ResourceModulen bestehen kann."@de .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_ResourceModule
KB1_ASRS:class_ResourceModule rdf:type owl:Class ;
                              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                owl:onProperty KB1_ASRS:op_hasFieldDevice ;
                                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass KB1_ASRS:class_FieldDevice
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty KB1_ASRS:op_isResourceModuleOf ;
                                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass KB1_ASRS:class_Resource
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty KB1_ASRS:op_providesSkill ;
                                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass [ rdf:type owl:Class ;
                                                              owl:unionOf ( KB1_ASRS:class_BasicSkill
                                                                            KB1_ASRS:class_CombinedSkill
                                                                          )
                                                            ]
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty KB1_ASRS:op_hasResourceModuleType ;
                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass KB1_ASRS:class_ResourceModuleType
                                              ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_ResourceModuleType
KB1_ASRS:class_ResourceModuleType rdf:type owl:Class .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_SelectedCapability
KB1_ASRS:class_SelectedCapability rdf:type owl:Class ;
                                  rdfs:subClassOf KB1_ASRS:class_Capability ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty KB1_ASRS:op_canFulfillServiceRequest ;
                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                    owl:onClass KB1_ASRS:class_ServiceRequest
                                                  ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_Sensor
KB1_ASRS:class_Sensor rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( KB1_ASRS:class_FieldDevice
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty KB1_ASRS:dp_isSensor ;
                                                                   owl:hasValue "true"^^xsd:boolean
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf KB1_ASRS:class_FieldDevice .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_ServiceRequest
KB1_ASRS:class_ServiceRequest rdf:type owl:Class ;
                              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                owl:onProperty KB1_ASRS:op_hasRequiredParameter ;
                                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass KB1_ASRS:class_ServiceRequestParameter
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty KB1_ASRS:op_hasServiceType ;
                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass KB1_ASRS:class_ServiceType
                                              ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_ServiceRequestParameter
KB1_ASRS:class_ServiceRequestParameter rdf:type owl:Class ;
                                       rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                         owl:onProperty KB1_ASRS:op_hasParameterType ;
                                                         owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass KB1_ASRS:class_ParameterType
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty KB1_ASRS:op_hasValueType ;
                                                         owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass KB1_ASRS:class_ValueType
                                                       ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_ServiceType
KB1_ASRS:class_ServiceType rdf:type owl:Class .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_Skill
KB1_ASRS:class_Skill rdf:type owl:Class .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_SkillParameter
KB1_ASRS:class_SkillParameter rdf:type owl:Class ;
                              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                owl:onProperty KB1_ASRS:op_hasParameterType ;
                                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass KB1_ASRS:class_ParameterType
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty KB1_ASRS:op_hasValueType ;
                                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass KB1_ASRS:class_ValueType
                                              ] ;
                              rdfs:comment "Individuals of Class Parameter shall be named after the Skill they belong to. E.g. If the Skill Individual called \"welding\" then the Individual in Class class_PositionParameter shall be called \"weldingPositionParameter\"." ,
                                           "Schweißen aus Sicht des Skills, nur für Skills, um Position bei In und Out eines Skills zu beschreiben" .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_TechnicalProcess
KB1_ASRS:class_TechnicalProcess rdf:type owl:Class ;
                                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                  owl:onProperty KB1_ASRS:op_realizesServiceRequest ;
                                                  owl:someValuesFrom KB1_ASRS:class_ServiceRequest
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty KB1_ASRS:op_hasTechnicalProcessStep ;
                                                  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                  owl:onClass KB1_ASRS:class_TechnicalProcessStep
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty KB1_ASRS:op_isExecutedOnResource ;
                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                  owl:onClass KB1_ASRS:class_Resource
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty KB1_ASRS:op_realizesServiceType ;
                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                  owl:onClass KB1_ASRS:class_ServiceType
                                                ] ;
                                rdfs:comment """Bei fehlender Capability, fehlende Capability feststellen und in Klasse herein.
- Service-Anfrage kommt herein und dann schauen, ob es was gibt. Mechanismus, der Instant kommt mit \"Kann ich nicht\", Klasse fehlende Capability:
        -1. Überprüfung vergangener langzeitgespeicherter TechnicalProcess (=Skillset,       was als Capability vorgeschlagen und angenommen wurde, nur dass variable Daten einen Frame haben)
      2. Falls nicht existent, neue Berechnung""" .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_TechnicalProcessStep
KB1_ASRS:class_TechnicalProcessStep rdf:type owl:Class ;
                                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                      owl:onProperty KB1_ASRS:op_hasParameterBinding ;
                                                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onClass KB1_ASRS:class_ParameterBinding
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty KB1_ASRS:op_hasTechnicalProcessStep ;
                                                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onClass KB1_ASRS:class_TechnicalProcessStep
                                                    ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_TechnicalRestriction
KB1_ASRS:class_TechnicalRestriction rdf:type owl:Class ;
                                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                      owl:onProperty KB1_ASRS:op_hasParameterType ;
                                                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onClass KB1_ASRS:class_ParameterType
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty KB1_ASRS:op_hasValueType ;
                                                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onClass KB1_ASRS:class_ValueType
                                                    ] .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_ValueType
KB1_ASRS:class_ValueType rdf:type owl:Class .


###  http://www.semanticweb.org/SkillOA/KnowledgeBase1/2026/v0.6/Demonstrator/I4.0/KB1_ASRS#class_WorkflowRestriction
KB1_ASRS:class_WorkflowRestriction rdf:type owl:Class ;
                                   rdfs:subClassOf KB1_ASRS:class_TechnicalRestriction .


